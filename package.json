{
  "name": "happy-hour-project",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "npx concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "cd web && npm run dev",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "test": "jest",
    "deploy": "npx cdk deploy --app 'npx ts-node infra/bin/app.ts' --require-approval never",
    "synth": "npx cdk synth --app 'npx ts-node infra/bin/app.ts'",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:rollback": "tsx src/db/migrate.ts down",
    "db:seed": "tsx src/db/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baxterstockman153/happy-hour-project.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/baxterstockman153/happy-hour-project/issues"
  },
  "homepage": "https://github.com/baxterstockman153/happy-hour-project#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1016.0",
    "@aws-sdk/client-secrets-manager": "^3.1024.0",
    "@aws-sdk/client-sns": "^3.1016.0",
    "@aws-sdk/s3-request-presigner": "^3.1016.0",
    "@vendia/serverless-express": "^4.12.6",
    "aws-cdk-lib": "^2.244.0",
    "bcryptjs": "^3.0.3",
    "constructs": "^10.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.1.2",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  }
}
